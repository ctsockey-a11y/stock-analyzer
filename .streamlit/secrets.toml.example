# Copy this file to secrets.toml for local use, OR paste this into
# Streamlit Community Cloud -> App -> Settings -> Secrets after deploying.
#
# IMPORTANT for cloud: Yahoo/yfinance blocks Streamlit's servers, so on the
# deployed app a free Finnhub key is what powers prices, fundamentals, insider
# trades, and news. Locally the app falls back to yfinance and works without it.
#   1. Sign up free at https://finnhub.io/register
#   2. Paste your API key below (keep the quotes).
FINNHUB_KEY = ""
